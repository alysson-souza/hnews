{
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ng serve",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "npm: start",
      "url": "http://localhost:4200/"
    },
    {
      "name": "Debug Vitest",
      "type": "node",
      "request": "launch",
      "autoAttachChildProcesses": true,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "program": "${workspaceRoot}/node_modules/.bin/ng",
      "args": ["test", "--", "--no-coverage", "--inspect-brk"],
      "console": "integratedTerminal"
    },
    {
      "name": "Debug Playwright",
      "type": "node",
      "request": "launch",
      "program": "${workspaceRoot}/node_modules/.bin/playwright",
      "args": ["test", "--headed", "--debug"],
      "console": "integratedTerminal",
      "env": {
        "PWDEBUG": "1"
      }
    }
  ]
}
