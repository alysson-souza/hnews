/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://www.google.com https://t0.gstatic.com; font-src 'self'; connect-src 'self' https://hacker-news.firebaseio.com https://hn.algolia.com https://raw.githubusercontent.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; worker-src 'self'

/index.html
  Cache-Control: no-cache

/index.csr.html
  Cache-Control: no-cache

/ngsw-worker.js
  Cache-Control: no-cache

/ngsw.json
  Cache-Control: no-cache

/version.json
  Cache-Control: no-cache

/manifest.webmanifest
  Cache-Control: no-cache
