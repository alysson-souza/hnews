{
  "name": "HNews Dev",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:22",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "angular.ng-template",
        "bradlc.vscode-tailwindcss",
        "christian-kohler.npm-intellisense",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "github.vscode-github-actions",
        "idered.npm",
        "ms-playwright.playwright",
        "SanaAjani.taskrunnercode"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
      }
    },
    "codespaces": {
      "openFiles": ["README.md", "CONTRIBUTING.md"]
    }
  },
  "forwardPorts": [4200, 8788],
  "portsAttributes": {
    "4200": {
      "label": "Angular Dev Server",
      "onAutoForward": "openBrowser"
    },
    "8788": {
      "label": "Wrangler Dev Server",
      "onAutoForward": "openBrowser"
    }
  },
  "mounts": [
    "source=${localWorkspaceFolderBasename}-node_modules,target=${containerWorkspaceFolder}/node_modules,type=volume"
  ],
  "postCreateCommand": "sudo chown node node_modules && npm install && npx playwright install --with-deps --no-shell chromium",
  "remoteUser": "node",
  "updateRemoteUserUID": true
}
